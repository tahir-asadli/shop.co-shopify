{% doc %}
  Renders a heading block.

  @example
  {% render 'button', link: block.settings.link %}
{% enddoc %}
{% render 'button', link: block.settings.link %}
{% schema %}
{
  "name": "Button",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Button URL"
    }
  ],
  "presets": [{ "name": "Button" }]
}
{% endschema %}
