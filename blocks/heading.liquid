{% render 'heading', text: block.settings.heading_text, size: block.settings.heading_size %}
{% schema %}
{
  "name": "Heading",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading Text"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "h1"
    }
  ],
  "presets": [{ "name": "Heading" }]
}
{% endschema %}
