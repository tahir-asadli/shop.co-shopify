{% comment %}
  Hero section for the Shopify theme.

  This section displays a hero banner with a title, description, call-to-action button,
  and an image. It also includes statistics about brands, products, and customers.

  Available settings:
  - background_image: Image picker for the section's background.
  - heading: Text for the main heading.
  - description: Text for the subheading or descriptive paragraph.
  - cta_button_text: Text for the call-to-action button.
  - cta_button_link: URL for the call-to-action button.
{% endcomment %}

<section
  class="hero-section w-full bg-slate-100 relative"
  {% if section.settings.background_image %}
    style="background-image: url({{ section.settings.background_image | image_url: width: 2000 }}); background-size: cover; background-position: center;"
  {% endif %}
>
  <div class="container px-4 pt-8 md:pt-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
      <!-- Left Content -->
      <div class="flex flex-col gap-6">
        <!-- Heading -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-black">
          {{ section.settings.heading }}
        </h1>
        <!-- Description -->
        <p class="text-base text-gray-600 leading-relaxed max-w-md">
          {{ section.settings.description }}
        </p>
        <!-- Shop Now Button -->
        {% if section.settings.cta_button_text != blank %}
          <a
            href="{{ section.settings.cta_button_link | default: '#' }}"
            class="bg-black text-white rounded-full px-12 py-4 font-medium w-fit hover:bg-gray-900 transition inline-block"
          >
            {{ section.settings.cta_button_text }}
          </a>
        {% endif %}
        <!-- Statistics -->
        <div class="grid grid-cols-3 gap-6 pt-4">
          <div>
            <p class="text-2xl md:text-3xl font-bold text-black">200+</p>
            <p class="text-sm text-gray-600">International Brands</p>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-bold text-black">2,000+</p>
            <p class="text-sm text-gray-600">High-Quality Products</p>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-bold text-black">30,000+</p>
            <p class="text-sm text-gray-600">Happy Customers</p>
          </div>
        </div>
      </div>
      <!-- Right Image -->
      <div class="flex justify-center md:justify-end">
        {% if section.settings.hero_image != blank %}
          {{ section.settings.hero_image |image_url: width: , height: | image_tag: width: 800, height: 600 }}
        {% else %}
          <img
            src="{{ 'hero.png' | asset_url }}"
            width="672"
            height="663"
            alt="Models wearing fashion"
            class="max-w-full h-auto"
          >
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Optional: Use a background image for the hero section."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FIND CLOTHES THAT MATCH YOUR STYLE"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Browse through our diverse range of meticulously crafted garments, designed to bring out your individuality and cater to your sense of style."
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image",
      "info": "Image displayed next to the text content. Overrides default 'hero.png' if set."
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "category": "Hero"
    }
  ]
}
{% endschema %}

{% stylesheet %}
  /* Add any specific styles for the hero section here if needed */
  .hero-section {
    /* Example: Ensure content is visible over background image */
    color: white; /* Default text color if background image is used */
  }

  /* Responsive adjustments for the hero section */
  @media (max-width: 768px) {
    .hero-section .grid-cols-3 {
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); /* Adjust for smaller screens */
    }
  }
{% endstylesheet %}
