              </h6>
              <div class="overflow-hidden filter-accordion-content">
                <div class="pt-5">
                  <div class="flex items-center gap-4 flex-wrap">
                    <div class="radio-size">
                      <input type="radio" name="size" id="small">
                      <label for="small">Small</label>
                    </div>
                    <div class="radio-size">
                      <input type="radio" name="size" id="medium">
                      <label for="medium">Medium</label>
                    </div>
                    <div class="radio-size">
                      <input type="radio" name="size" id="large">
                      <label for="large">Large</label>
                    </div>
                    <div class="radio-size">
                      <input type="radio" name="size" id="x-large">
                      <label for="x-large">X-Large</label>
                    </div>
                  </div>
                </div>
              </div>
            </filter-accordion>
            <filter-accordion class="block border-b border-b-black/10 pb-6 mb-6 filter-accordion accordion-open">
              <h6 class="font-bold flex gap-2 justify-between items-center cursor-pointer filter-accordion-header">
