{% comment %}
  This section is used in the collection template to render collection page
  listing all products within a collection.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/collection
{% endcomment %}

<section class="pb-40">
  <div class="container">
    <div class="grid md:grid-cols-[300px_auto] gap-5">
      <div>
        <div>
          <div class="border border-black/10 py-5 px-6 rounded-[20px]">
            <div class="border-b border-b-black/10 pb-6 mb-6">
              <h6 class="font-bold flex gap-2 justify-between items-center">
                <span>Filters</span>
                {% render 'icon', icon: 'filter', class: 'size-6' %}
              </h6>
            </div>
            <collection-filters data-collection-handle="{{ collection.handle }}" data-section-id="{{ section.id }}">
              <div>
                {% for filter in collection.filters %}
                  <filter-accordion class="block border-b border-b-black/10 pb-6 mb-6 filter-accordion accordion-open">
                    <h6
                      href="{{ filter.url }}"
                      class="font-bold flex gap-2 justify-between items-center cursor-pointer filter-accordion-header"
                    >
                      <span>{{ filter.label }}</span>
                      {% render 'icon',
                        icon: 'down-chevron',
                        class: 'size-3 transition-all in-[.accordion-open]:rotate-180'
                      %}
                    </h6>
                    <div class="overflow-hidden filter-accordion-content">
                      <div class="pt-5">
                        {% if filter.type == 'list' or filter.type == 'boolean' %}
                          {% for value in filter.values %}
                            <div>
                              <input
                                name="filter-{{ filter.label|handleize }}"
                                data-add-url="{{ value.url_to_add }}"
                                data-remove-url="{{ value.url_to_remove }}"
                                {% if value.active %}
                                  checked
                                {% endif %}
                                id="filter-{{ filter.label|handleize }}-{{ value.label|handleize }}"
                                type="checkbox"
                              >
                              <label for="filter-{{ filter.label|handleize }}-{{ value.label|handleize }}">
                                {{- value.label -}}
                              </label>
                            </div>
                          {% endfor %}
                        {% else %}

                        {% endif %}
                        Filter content{{ filter.type }}
                      </div>
                    </div>
                  </filter-accordion>
                {% endfor %}
              </div>
            </collection-filters>
            <div class="border-b border-b-black/10 pb-6 mb-6">
              <ul class=" flex flex-col gap-2">
                <li>
                  <a href="/" class="flex gap-2 justify-between items-center text-black/60 py-1"
                    ><span>T-shirts</span>
                    {% render 'icon', icon: 'right-chevron', class: 'size-3 text-black/60' %}
                  </a>
                </li>
                <li>
                  <a href="/" class="flex gap-2 justify-between items-center text-black/60 py-1"
                    ><span>Shorts</span>
                    {% render 'icon', icon: 'right-chevron', class: 'size-3 text-black/60' %}
                  </a>
                </li>
                <li>
                  <a href="/" class="flex gap-2 justify-between items-center text-black/60 py-1"
                    ><span>Shirts</span>
                    {% render 'icon', icon: 'right-chevron', class: 'size-3 text-black/60' %}
                  </a>
                </li>
                <li>
                  <a href="/" class="flex gap-2 justify-between items-center text-black/60 py-1"
                    ><span>Hoodie</span>
                    {% render 'icon', icon: 'right-chevron', class: 'size-3 text-black/60' %}
                  </a>
                </li>
                <li>
                  <a href="/" class="flex gap-2 justify-between items-center text-black/60 py-1"
                    ><span>Jeans</span>
                    {% render 'icon', icon: 'right-chevron', class: 'size-3 text-black/60' %}
                  </a>
                </li>
              </ul>
            </div>
            <filter-accordion class="block border-b border-b-black/10 pb-6 mb-6 filter-accordion accordion-open">
              <h6 class="font-bold flex gap-2 justify-between items-center cursor-pointer filter-accordion-header">
                <span>Price</span>
                {% render 'icon',
                  icon: 'down-chevron',
                  class: 'size-3 transition-all in-[.accordion-open]:rotate-180'
                %}
              </h6>
              <div class="overflow-hidden filter-accordion-content">
                <div class="pt-5">
                  <input type="range" min="1" max="1000" value="50" class="slider">
                  <div class="mt-1">50</div>
                </div>
              </div>
            </filter-accordion>
            <filter-accordion class="block border-b border-b-black/10 pb-6 mb-6 filter-accordion accordion-open">
              <h6 class="font-bold flex gap-2 justify-between items-center cursor-pointer filter-accordion-header">
                <span>Colors</span>
                {% render 'icon',
                  icon: 'down-chevron',
                  class: 'size-3 transition-all in-[.accordion-open]:rotate-180'
                %}
              </h6>
              <div class="overflow-hidden filter-accordion-content">
                <div class="pt-5">
                  <div class="flex items-center gap-4 flex-wrap">
                    <div class="radio">
                      <input type="radio" name="color" checked id="brown" class="">
