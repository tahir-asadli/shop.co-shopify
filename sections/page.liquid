{% comment %}
  This section is used in the page template to render store pages like About us
  or Contact us.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/page
{% endcomment %}
<section>
  <div class="container">
    <h1 class="h3 uppercase mb-3">{{ page.title }}</h1>
    <div class="py-3">{{ page.content }}</div>
  </div>
</section>

{% schema %}
{
  "name": "t:general.page",
  "settings": []
}
{% endschema %}
